backend/.coverage
backend/.pytest_cache/
backend/instance/
backend/.webassets-cache

# Logs
*.log
backend/logs/
frontend/logs/

# Database
*.db
*.sqlite3

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
.DS_Store?
._*
